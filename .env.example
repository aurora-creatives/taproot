# ═══════════════════════════════════════════════════════════════════
# taproot configuration
# Copy this file to .env and fill in the values for your setup.
# ═══════════════════════════════════════════════════════════════════

# ── Router ─────────────────────────────────────────────────────────
# single: one model handles everything (simplest setup)
# multi:  each task gets its own model (optimise cost + capability)
LLM_MODE=single

# ── Single mode ────────────────────────────────────────────────────
# Used when LLM_MODE=single. Ignored in multi mode.
LLM_PROVIDER=anthropic        # anthropic | openai | azure_openai | aws_bedrock
LLM_MODEL=claude-sonnet-4-20250514

# ── Multi mode ─────────────────────────────────────────────────────
# Used when LLM_MODE=multi. Each task routes independently.
# Provider credentials below are shared — no duplication of API keys.
#
# rerank   → fast, cheap, high volume (reranking search results)
# analysis → your most capable model (pattern reasoning across tickets)
# draft    → balanced (structured problem record output)
#
LLM_RERANK_PROVIDER=openai
LLM_RERANK_MODEL=gpt-4o-mini

LLM_ANALYSIS_PROVIDER=anthropic
LLM_ANALYSIS_MODEL=claude-sonnet-4-20250514

LLM_DRAFT_PROVIDER=azure_openai
LLM_DRAFT_MODEL=gpt-4o

# ── Shared Provider Credentials ────────────────────────────────────
# Set only the credentials for providers you actually use.

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI (Recommended: regulated and enterprise environments)
# Data stays within your Azure tenant. Satisfies GDPR, SOC 2, HIPAA BAA.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# AWS Bedrock (Recommended: regulated and enterprise environments)
# Data stays within your AWS account.
AWS_BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ── Privacy and Compliance ─────────────────────────────────────────
# ENABLE_SCRUBBING: anonymise PII in ticket content before any LLM call.
# Runs locally. Wraps whichever provider is active — in any mode.
ENABLE_SCRUBBING=false
SCRUBBING_LEVEL=standard     # standard | aggressive

# ── Data Source ────────────────────────────────────────────────────
# true  = use synthetic fixture data (default, no ITSM credentials needed)
# false = use real ITSM integration (requires credentials below)
USE_MOCK_DATA=true
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── PageIndex ──────────────────────────────────────────────────────
# Retrieval runs entirely locally. No data leaves.
PAGEINDEX_USE_SEMANTIC=true
PAGEINDEX_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Output ─────────────────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_LEVEL=INFO
